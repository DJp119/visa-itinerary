---
// This is a static version - the interactive version would be a React island
---
<section class="min-h-[600px] relative bg-gradient-to-b from-primary-50 to-primary-100 overflow-hidden">
  <div class="absolute inset-0">
    <div class="relative h-full w-full">
      <div class="absolute inset-0 bg-[url('/images/hero-background.jpg')] bg-center bg-cover opacity-20"></div>
    </div>
  </div>
  <div class="relative z-10 flex flex-col items-center py-20 px-4 text-center">
    <h1 class="text-4xl font-bold text-primary-900 mb-6">
      Discover Your Next Destination
    </h1>
    <p class="text-lg text-primary-700 mb-8 max-w-2xl">
      Find visa requirements, travel information, and essential tips for countries around the world.
    </p>
    <!-- In a real implementation, this would be a React island -->
    <div class="flex flex-col sm:flex-row gap-4 max-w-xl w-full">
      <input
        type="text"
        placeholder="Where are you from?"
        class="flex-1 px-4 py-3 rounded-l-lg border border-border bg-background/80 text-foreground placeholder:text-foreground/40 focus:outline-none focus:ring-2 focus:ring-primary-500"
      />
      <input
        type="text"
        placeholder="Where do you want to go?"
        class="flex-1 px-4 py-3 border border-border bg-background/80 text-foreground placeholder:text-foreground/40 focus:outline-none focus:ring-2 focus:ring-primary-500"
      />
      <button
        class="px-6 py-3 bg-primary-500 text-primary-foreground hover:bg-primary-600 transition-colors rounded-r-lg flex-1 sm:px-8"
      >
        Search
      </button>
    </div>
  </div>
</section>