---
import WidgetBuilder from '@/components/islands/WidgetBuilder';
---
<div class="widget-container border border-border/50 rounded-lg p-4 max-w-2xl mx-auto bg-background">
  <div class="widget-header flex items-center justify-between mb-4 pb-2 border-b border-border/50">
    <div class="flex items-center space-x-3">
      <div class="h-8 w-8 flex-shrink-0 flex items-center justify-center bg-primary-500/10 text-primary-500">
        </div>
      <h3 class="text-lg font-semibold text-foreground">Visa Checker Widget</h3>
    </div>
    <div class="text-sm text-foreground/50">
      v1.2.3
    </div>
  </div>

  <WidgetBuilder client:only="react" />
</div>

<style>
  .widget-container {
    font-family: system-ui, sans-serif;
  }
</style>