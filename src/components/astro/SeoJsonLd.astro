---
const {
  type,
  title,
  description,
  image,
  path,
  ...props
} = Astro.props;

import { generateMetaTags } from '@/lib/seo/meta';
import { generateJsonLd, jsonLdGenerators } from '@/lib/seo/jsonLd';

// Helper function to get site URL
function getSiteUrl() {
  return typeof window !== 'undefined'
    ? window.location.origin
    : 'https://visaitinerary.example.com';
}
---

{/* Meta Tags */}
<Fragment set:html={generateMetaTags({
  title: title || 'Visa Itinerary',
  description: description,
  image: image,
  path: Astro.url.pathname,
  siteName: 'Visa Itinerary'
})} />

{/* JSON-LD Structured Data */}
{props.type && (
  <>
    <Fragment set:html={generateJsonLd({
      type: props.type,
      ...props
    })} />

    {/* Additional common JSON-LD based on type */}
    {props.type === 'WebSite' && (
      <Fragment set:html={generateJsonLd(jsonLdGenerators.website({
        name: title || 'Visa Itinerary',
        url: `${getSiteUrl()}`,
        description: description,
        publisherName: 'Visa Itinerary',
        publisherLogo: image
      }))} />
    )}

    {props.type === 'BreadcrumbList' && (
      <Fragment set:html={generateJsonLd(jsonLdGenerators.breadcrumbList({
        items: props.items || []
      }))} />
    )}

    {props.type === 'FAQPage' && (
      <Fragment set:html={generateJsonLd(jsonLdGenerators.faqPage({
        question: props.question || '',
        answer: props.answer || ''
      }))} />
    )}

    {props.type === 'ItemList' && (
      <Fragment set:html={generateJsonLd(jsonLdGenerators.itemList({
        name: props.name || '',
        itemListElement: props.items || []
      }))} />
    )}

    {props.type === 'Article' && (
      <Fragment set:html={generateJsonLd(jsonLdGenerators.article({
        headline: title || '',
        description: description,
        image: image,
        authorName: props.authorName,
        publisherName: 'Visa Itinerary',
        publisherLogo: image,
        datePublished: props.datePublished,
        dateModified: props.dateModified
      }))} />
    )}
  </>
)}