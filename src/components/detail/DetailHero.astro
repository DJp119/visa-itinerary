---
const {
  title,
  description,
  image,
  lastUpdated,
  className
} = Astro.props;
---
<div class={`mb-8 ${className}`}>
  {image && (
    <div class="mb-6">
      <img
        src={image}
        alt={title}
        class="w-full h-64 object-cover rounded-lg"
      />
    </div>
  )}
  <h1 class="text-3xl font-bold text-foreground mb-4">
    {title}
  </h1>
  {description && (
    <p class="text-lg text-foreground/60 mb-4">{description}</p>
  )}
  {lastUpdated && (
    <p class="text-sm text-foreground/40">
      Last updated: {new Date(lastUpdated).toLocaleDateString()}
    </p>
  )}
</div>