---
// Layout for authenticated user pages
import { ToastProvider } from '@/components/islands/ToastProvider';
import { useAuth } from '@/lib/auth';
import { useState } from 'react';
---
<!DOCTYPE html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>
      {Astro.props.pageTitle ?? 'Account'} | Visa Itinerary
    </title>
    <meta name="description" content={Astro.props.pageDescription} />
    <meta name="theme-color" content="#ffffff" />
  </head>
  <body class="min-h-flex flex-col">
    <ToastProvider>
      <ClientOnly>
        <AuthenticatedHeader />
      </ClientOnly>
      <main class="flex-grow pt-[4rem]">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
          <slot />
        </div>
      </main>

      <footer class="mt-auto bg-footer text-primary-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
          <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <div>
              <h3 class="text-xl font-bold mb-4">Visa Itinerary</h3>
              <p class="text-primary-200">
                Discover visa requirements and travel information for destinations worldwide.
              </p>
            </div>
            <div>
              <h4 class="font-semibold mb-3">Resources</h4>
              <ul class="space-y-2 text-primary-200">
                <li><a href="/about" class="hover:text-primary-100 transition-colors">About</a></li>
                <li><a href="/contact" class="hover:text-primary-100 transition-colors">Contact</a></li>
                <li><a href="/open" class="hover:text-primary-100 transition-colors">Open Metrics</a></li>
                <li><a href="/integrate" class="hover:text-primary-100 transition-colors">Integrate</a></li>
              </ul>
            </div>
            <div>
              <h4 class="font-semibold mb-3">Legal</h4>
              <ul class="space-y-2 text-primary-200">
                <li><a href="/terms" class="hover:text-primary-100 transition-colors">Terms of Service</a></li>
                <li><a href="/privacy" class="hover:text-primary-100 transition-colors">Privacy Policy</a></li>
                <li><a href="/disclaimer" class="hover:text-primary-100 transition-colors">Disclaimer</a></li>
              </ul>
            </div>
          </div>
          <div class="mt-12 pt-8 border-t border-border/50 text-center text-primary-300 text-sm">
            &copy; {new Date().getFullYear()} Visa Itinerary. All rights reserved.
          </div>
        </div>
      </footer>
    </ToastProvider>
  </body>
</html>

---
// AuthenticatedHeader React component
import { useAuth } from '@/lib/auth';
import { useNavigate } from '@tanstack/react-router';

function AuthenticatedHeader() {
  const { user, logout } = useAuth();
  const navigate = useNavigate();

  const handleLogout = async () => {
    await logout();
    navigate('/');
  };

  return (
    <header className="fixed top-0 left-0 right-0 z-50 bg-background/95 backdrop-blur-sm border-b border-border">
      <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex h-16 items-center justify-between">
        <div className="flex-shrink-0 flex items-center space-x-3">
          <a href="/" className="text-primary-500 hover:text-primary-600 font-bold text-xl">
            Visa Itinerary
          </a>
        </div>
        <nav className="hidden md:flex space-x-4">
          <a href="/user/profile" className={`${user && Astro.url.pathname === '/user/profile' ? 'text-foreground' : 'text-foreground/70'} hover:text-foreground transition-colors px-3 py-1 rounded text-sm`}>
            Profile
          </a>
          <a href="/user/subscription" className={`${user && Astro.url.pathname === '/user/subscription' ? 'text-foreground' : 'text-foreground/70'} hover:text-foreground transition-colors px-3 py-1 rounded text-sm`}>
            Subscription
          </a>
          <a href="/dashboard" className={`${user && Astro.url.pathname.startsWith('/dashboard') ? 'text-foreground' : 'text-foreground/70'} hover:text-foreground transition-colors px-3 py-1 rounded text-sm`}>
            Dashboard
          </a>
        </nav>
        <div className="flex-shrink-0 flex items-center space-x-3">
          {user && (
            <div className="relative">
              <button
                onClick={handleLogout}
                className="btn-outline px-4 py-2 rounded-md text-sm"
              >
                Logout
              </div>
          )}
        </div>
      </div>
    </header>
  );
}
</AuthenticatedHeader>