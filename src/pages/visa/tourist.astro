---
import SiteLayout from '@/layouts/SiteLayout.astro';
import Container from '@/components/astro/Container.astro';
import SectionHeader from '@/components/astro/SectionHeader.astro';
import DirectoryCard from '@/components/directory/DirectoryCard.astro';
import { getCountryStaticPaths } from '@/lib/urls/routes';

// This is a static version - in a real implementation we would fetch from repositories
export async function getStaticPaths() {
  return getCountryStaticPaths().map(path => ({
    params: {}
  }));
}

// Mock data for the tourist visa directory
async function getData() {
  // TODO: Fetch actual country data from repository
  // For now, return mock data
  const countries = [
    {
      id: 'usa',
      name: 'United States of America',
      shortName: 'USA',
      iso2: 'US',
      iso3: 'USA',
      heroImage: '/images/countries/usa/hero.jpg',
      stats: [
        { label: 'Visa Fee', value: '$160' },
        { label: 'Stay Duration', value: 'Up to 180 days' },
        { label: 'Processing Time', value: '3-10 days' }
      ]
    },
    {
      id: 'can',
      name: 'Canada',
      shortName: 'CAN',
      iso2: 'CA',
      iso3: 'CAN',
      heroImage: '/images/countries/can/hero.jpg',
      stats: [
        { label: 'Visa Fee', value: 'CAD $100' },
        { label: 'Stay Duration', value: 'Up to 6 months' },
        { label: 'Processing Time', value: '4-6 weeks' }
      ]
    },
    {
      id: 'deu',
      name: 'Germany',
      shortName: 'DEU',
      iso2: 'DE',
      iso3: 'DEU',
      heroImage: '/images/countries/deu/hero.jpg',
      stats: [
        { label: 'Visa Fee', value: '€80' },
        { label: 'Stay Duration', value: 'Up to 90 days' },
        { label: 'Processing Time', value: '1-3 weeks' }
      ]
    }
  ];

  return {
    props: {
      countries: countries
    }
  };
}

const _data = await getData({ params: Astro.params });
const props = _data?.props || {};
---

<SiteLayout
  pageTitle="Tourist Visa Directory"
  pageDescription="Find tourist visa requirements for countries around the world."
>
  <Container>
    <section class="mb-12">
      <h1 class="text-4xl font-bold text-center mb-6">
        Tourist Visa Directory
      </h1>
      <p class="text-lg text-center max-w-3xl mx-auto text-foreground/60">
        Discover tourist visa requirements for countries worldwide. Select your destination to learn about
        visa types, fees, processing times, and application requirements.
      </p>
    </section>

    <div class="space-y-8">
      {props.countries.map((country, index) => (
        <DirectoryCard
          key={index}
          title={country.name}
          description={`Learn about tourist visa requirements for visiting ${country.name}`}
          image={country.heroImage}
          stats={country.stats}
          href={`/${country.iso2.toLowerCase()}/tourist`}
          className="hover:shadow-lg transition-shadow duration-200"
        />
      ))}
    </div>
  </Container>
</SiteLayout>