---
import AccountLayout from '@/layouts/AccountLayout.astro';
import Container from '@/components/astro/Container.astro';
import SectionHeader from '@/components/astro/SectionHeader.astro';

async function getData() {
  return {
    props: {}
  };
}

const _data = await getData({ params: Astro.params });
const props = _data?.props || {};
---

<AccountLayout
  pageTitle="Billing History"
  pageDescription="View your complete billing and invoice history"
>
  <Container>
    <section class="mb-8">
      <div class="space-y-4">
        <div class="flex items-center mb-4">
          <h2 class="text-2xl font-bold text-foreground">
            Billing History
          </h2>
          <a href="/billing" class="text-sm font-medium text-primary-500 hover:text-primary-600 transition-colors">
            ← Back to Billing Settings
          </a>
        </div>
        <p class="text-sm text-foreground/50">
          View and download all your invoices and payment receipts.
        </p>
      </div>
    </section>

    <section class="space-y-6">
      {/* Filters */}
      <div class="bg-background/50 rounded-lg p-6 border border-border/50 mb-6">
        <h3 class="text-lg font-semibold mb-4">
          Filter & Export
        </h3>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
          <div>
            <label class="block text-sm font-medium text-foreground mb-2">
              Date Range
            </label>
            <select class="w-full px-3 py-2 rounded-md bg-background/80 border border-border/50 text-sm">
              <option value="last-30">Last 30 Days</option>
              <option value="last-90">Last 90 Days</option>
              <option value="last-year" selected>Last Year</option>
              <option value="custom">Custom Range</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-foreground mb-2">
              Status
            </label>
            <select class="w-full px-3 py-2 rounded-md bg-background/80 border border-border/50 text-sm">
              <option value="all" selected>All Statuses</option>
              <option value="paid">Paid</option>
              <option value="pending">Pending</option>
              <option value="failed">Failed</option>
              <option value="refunded">Refunded</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-foreground mb-2">
              Format
            </label>
            <select class="w-full px-3 py-2 rounded-md bg-background/80 border border-border/50 text-sm">
              <option value="pdf" selected>PDF</option>
              <option value="csv">CSV</option>
              <option value="excel">Excel</option>
            </select>
          </div>
          <div class="flex items-end">
            <button
              class="w-full bg-primary-500 text-primary-foreground py-3 rounded-lg font-medium hover:bg-primary-600 transition-colors"
            >
              Export
            </button>
          </div>
        </div>
      </div>

      {/* Invoice List */}
      <div class="bg-background/50 rounded-lg p-6 border border-border/50">
        <h3 class="text-lg font-semibold mb-4">
          Invoices
        </h3>
        <div class="space-y-4">
          {/* Invoice items */}
          <div class="space-y-5">
            <!-- Invoice 1 -->
            <div class="border border-border/50 rounded-lg p-4">
              <div class="grid gap-4 sm:grid-cols-3 items-start">
                <div class="space-y-2">
                  <p class="font-medium text-foreground">
                    Invoice #VIS-2026-003
                  </p>
                  <p class="text-sm text-foreground/50">
                    June 15, 2026 • Pro Plan Monthly
                  </p>
                </div>
                <div class="space-y-2">
                  <p class="font-medium text-foreground">
                    $9.99
                  </p>
                  <p class="text-sm text-foreground/50">
                    Amount due
                  </p>
                </div>
                <div class="space-y-2 text-right">
                  <span class="px-3 py-1 rounded-full text-xs bg-success-100 text-success-800">
                    Paid
                  </span>
                  <a href="#" class="mt-2 inline-flex items-center px-3 py-1 rounded-md text-sm text-primary-500 hover:text-primary-600 transition-colors">
                    Download PDF
                  </a>
                </div>
              </div>
              <div class="h-px my-3 bg-border/50"></div>
              <div class="text-sm text-foreground/50">
                Billed to: Visa •••• 4242
              </div>
            </div>

            <!-- Invoice 2 -->
            <div class="border border-border/50 rounded-lg p-4">
              <div class="grid gap-4 sm:grid-cols-3 items-start">
                <div class="space-y-2">
                  <p class="font-medium text-foreground">
                    Invoice #VIS-2026-002
                  </p>
                  <p class="text-sm text-foreground/50">
                    May 15, 2026 • Pro Plan Monthly
                  </p>
                  <div class="mt-2 flex flex-wrap gap-2">
                    <span class="px-2 py-0.5 rounded-full text-xs bg-primary-100 text-primary-800">
                      Tax Included
                    </span>
                  </div>
                </div>
                <div class="space-y-2">
                  <p class="font-medium text-foreground">
                    $9.99
                  </p>
                  <p class="text-sm text-foreground/50">
                    Amount due
                  </p>
                </div>
                <div class="space-y-2 text-right">
                  <span class="px-3 py-1 rounded-full text-xs bg-success-100 text-success-800">
                    Paid
                  </span>
                  <a href="#" class="mt-2 inline-flex items-center px-3 py-1 rounded-md text-sm text-primary-500 hover:text-primary-600 transition-colors">
                    Download PDF
                  </a>
                </div>
              </div>
              <div class="h-px my-3 bg-border/50"></div>
              <div class="text-sm text-foreground/50">
                Billed to: Visa •••• 4242
              </div>
            </div>

            <!-- Invoice 3 -->
            <div class="border border-border/50 rounded-lg p-4">
              <div class="grid gap-4 sm:grid-cols-3 items-start">
                <div class="space-y-2">
                  <p class="font-medium text-foreground">
                    Invoice #VIS-2026-001
                  </p>
                  <p class="text-sm text-foreground/50">
                    April 15, 2026 • Pro Plan Monthly
                  </p>
                </div>
                <div class="space-y-2">
                  <p class="font-medium text-foreground">
                    $9.99
                  </p>
                  <p class="text-sm text-foreground/50">
                    Amount due
                  </p>
                </div>
                <div class="space-y-2 text-right">
                  <span class="px-3 py-1 rounded-full text-xs bg-success-100 text-success-800">
                    Paid
                  </span>
                  <a href="#" class="mt-2 inline-flex items-center px-3 py-1 rounded-md text-sm text-primary-500 hover:text-primary-600 transition-colors">
                    Download PDF
                  </a>
                </div>
              </div>
              <div class="h-px my-3 bg-border/50"></div>
              <div class="text-sm text-foreground/50">
                Billed to: Visa •••• 4242
              </div>
            </div>

            <!-- Invoice 4 -->
            <div class="border border-border/50 rounded-lg p-4">
              <div class="grid gap-4 sm:grid-cols-3 items-start">
                <div class="space-y-2">
                  <p class="font-medium text-foreground">
                    Invoice #VIS-2025-012
                  </p>
                  <p class="text-sm text-foreground/50">
                    March 15, 2025 • Pro Plan Monthly
                  </p>
                </div>
                <div class="space-y-2">
                  <p class="font-medium text-foreground">
                    $9.99
                  </p>
                  <p class="text-sm text-foreground/50">
                    Amount due
                  </p>
                </div>
                <div class="space-y-2 text-right">
                  <span class="px-3 py-1 rounded-full text-xs bg-success-100 text-success-800">
                    Paid
                  </span>
                  <a href="#" class="mt-2 inline-flex items-center px-3 py-1 rounded-md text-sm text-primary-500 hover:text-primary-600 transition-colors">
                    Download PDF
                  </a>
                </div>
              </div>
              <div class="h-px my-3 bg-border/50"></div>
              <div class="text-sm text-foreground/50">
                Billed to: Visa •••• 4242
              </div>
            </div>
          </div>

          {/* Load more button */}
          <div class="mt-6">
            <button
              class="w-full bg-transparent border border-primary-500 text-primary-500 px-4 py-2 rounded-md hover:bg-primary-50 transition-colors"
            >
              Load More Invoices
            </button>
          </div>
        </div>
      </div>
    </section>
  </Container>
</AccountLayout>