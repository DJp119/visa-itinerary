---
import AccountLayout from '@/layouts/AccountLayout.astro';
import Container from '@/components/astro/Container.astro';
import SectionHeader from '@/components/astro/SectionHeader.astro';

export async function get() {
  return {
    props: {}
  };
}
---

<AccountLayout
  pageTitle="Billing Settings"
  pageDescription="Update your payment method and billing preferences"
>
  <Container>
    <section class="mb-8">
      <div class="space-y-4">
        <div class="flex items-center mb-4">
          <h2 class="text-2xl font-bold text-foreground">
            Billing Settings
          </h2>
        </div>
        <p class="text-sm text-foreground/50">
          Manage your payment methods, invoices, and subscription preferences.
        </p>
      </div>
    </section>

    <section class="space-y-6">
      {/* Payment Method */}
      <div class="bg-background/50 rounded-lg p-6 border border-border/50">
        <h3 class="text-lg font-semibold mb-4">
          Payment Method
        </h3>
        <div class="space-y-4">
          <div class="flex items-center mb-4">
            <div class="h-8 w-8 flex-shrink-0 flex items-center justify-center bg-primary-500/20 text-primary-500">
              </div>
            <div class="ml-3">
              <h4 class="font-semibold text-foreground">
                Visa •••• 4242
              </h4>
              <p class="text-sm text-foreground/50">
                Expires 12/27
              </p>
            </div>
          </div>

          <div class="bg-background/80 p-4 rounded-lg">
            <div class="flex items-center space-x-3">
              <div class="h-6 w-6 flex-shrink-0 flex items-center justify-center bg-primary-500/20 text-primary-500">
                </div>
              <div>
                <p class="font-medium text-foreground">
                  Default for new subscriptions
                </p>
                <p class="text-sm text-foreground/50">
                  Will be used for upcoming payments
                </p>
              </div>
            </div>
          </div>

          <button class="w-full bg-primary-500 text-primary-foreground py-3 rounded-lg font-medium hover:bg-primary-600 transition-colors">
            Update Payment Method
          </button>
        </div>
      </div>

      {/* Subscription Plan */}
      <div class="bg-background/50 rounded-lg p-6 border border-border/50">
        <h3 class="text-lg font-semibold mb-4">
          Subscription Plan
        </h3>
        <div class="space-y-4">
          <div class="flex items-center mb-4">
            <div class="h-8 w-8 flex-shrink-0 flex items-center justify-center bg-primary-500/20 text-primary-500">
              </div>
            <div class="ml-3">
              <h4 class="font-semibold text-foreground">
                Pro Plan
              </h4>
              <p class="text-sm text-foreground/50">
                Monthly • $9.99/month
              </p>
            </div>
          </div>

          <div class="space-y-3">
            <p class="text-sm text-foreground/50">
              Next billing date: July 15, 2026
            </p>
          </div>

          <div class="space-y-4 pt-4 border-t border-border/50">
            <div class="grid gap-3 sm:grid-cols-2">
              <button
                class="w-full bg-transparent border border-primary-500 text-primary-500 px-4 py-2 rounded-md hover:bg-primary-50 transition-colors"
              >
                Switch to Annual
              </button>
              <button
                class="w-full bg-primary-500 text-primary-foreground py-3 rounded-lg font-medium hover:bg-primary-600 transition-colors"
              >
                Update Plan
              </button>
            </div>
          </div>
        </div>
      </div>

      {/* Invoice History */}
      <div class="bg-background/50 rounded-lg p-6 border border-border/50">
        <h3 class="text-lg font-semibold mb-4">
          Invoice History
        </h3>
        <div class="space-y-3">
          <div class="flex justify-between mb-3">
            <span class="text-sm text-foreground/50">
              3 Invoices
            </span>
            <a href="/billing/history" class="text-sm font-medium text-primary-500 hover:text-primary-600 transition-colors">
              View All
            </a>
          </div>

          <div class="space-y-4">
            {/* Recent invoices */}
            <div class="space-y-3">
              <div class="flex justify-between items-start">
                <div>
                  <p class="font-medium text-foreground">
                    Invoice #VIS-2026-003
                  </p>
                  <p class="text-sm text-foreground/50">
                    June 15, 2026
                  </p>
                </div>
                <div class="text-right">
                  <p class="font-medium text-foreground">
                    $9.99
                  </p>
                  <span class="px-2 py-0.5 rounded-full text-xs bg-success-100 text-success-800">
                    Paid
                  </span>
                </div>
              </div>
              <div class="h-px my-3 bg-border/50"></div>

              <div class="flex justify-between items-start">
                <div>
                  <p class="font-medium text-foreground">
                    Invoice #VIS-2026-002
                  </p>
                  <p class="text-sm text-foreground/50">
                    May 15, 2026
                  </p>
                </div>
                <div class="text-right">
                  <p class="font-medium text-foreground">
                    $9.99
                  </p>
                  <span class="px-2 py-0.5 rounded-full text-xs bg-success-100 text-success-800">
                    Paid
                  </span>
                </div>
              </div>
              <div class="h-px my-3 bg-border/50"></div>

              <div class="flex justify-between items-start">
                <div>
                  <p class="font-medium text-foreground">
                    Invoice #VIS-2026-001
                  </p>
                  <p class="text-sm text-foreground/50">
                    April 15, 2026
                  </p>
                </div>
                <div class="text-right">
                  <p class="font-medium text-foreground">
                    $9.99
                  </p>
                  <span class="px-2 py-0.5 rounded-full text-xs bg-success-100 text-success-800">
                    Paid
                  </span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </Container>
</AccountLayout>