---
import SiteLayout from '@/layouts/SiteLayout.astro';
import Container from '@/components/astro/Container.astro';
import SectionHeader from '@/components/astro/SectionHeader.astro';
---

<SiteLayout
  pageTitle="Contact Us"
  pageDescription="Get in touch with the Visa Itinerary team"
>
  <Container>
    <SectionHeader
      title="Contact Us"
      description="Get in touch with the Visa Itinerary team"
    >
      <div class="grid gap-8 sm:grid-cols-1 lg:grid-cols-2">
        {/* Contact Form */}
        <div>
          <form action="#" method="post" class="space-y-6">
            <div class="grid gap-4 sm:grid-cols-2">
              <div>
                <label for="firstName" class="block text-sm font-medium text-foreground mb-2">
                  First Name
                </label>
                <input
                  type="text"
                  id="firstName"
                  name="firstName"
                  required
                  class="w-full px-4 py-3 rounded-lg border border-border bg-background/80 text-foreground placeholder:text-foreground/40 focus:outline-none focus:ring-2 focus:ring-primary-500"
                />
              </div>
              <div>
                <label for="lastName" class="block text-sm font-medium text-foreground mb-2">
                  Last Name
                </label>
                <input
                  type="text"
                  id="lastName"
                  name="lastName"
                  required
                  class="w-full px-4 py-3 rounded-lg border border-border bg-background/80 text-foreground placeholder:text-foreground/40 focus:outline-none focus:ring-2 focus:ring-primary-500"
                />
              </div>
            </div>

            <div>
              <label for="email" class="block text-sm font-medium text-foreground mb-2">
                Email Address
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full px-4 py-3 rounded-lg border border-border bg-background/80 text-foreground placeholder:text-foreground/40 focus:outline-none focus:ring-2 focus:ring-primary-500"
              />
            </div>

            <div>
              <label for="subject" class="block text-sm font-medium text-foreground mb-2">
                Subject
              </label>
              <select
                id="subject"
                name="subject"
                required
                class="w-full px-4 py-3 rounded-lg border border-border bg-background/80 text-foreground placeholder:text-foreground/40 focus:outline-none focus:ring-2 focus:ring-primary-500"
              >
                <option value="">Select a subject</option>
                <option value="general">General Inquiry</option>
                <option value="partnership">Partnership Opportunity</option>
                <option value="feedback">Feedback or Suggestion</option>
                <option value="support">Support Request</option>
                <option value="legal">Legal/Copyright Concern</option>
              </select>
            </div>

            <div>
              <label for="message" class="block text-sm font-medium text-foreground mb-2">
                Message
              </label>
              <textarea
                id="message"
                name="message"
                rows="6"
                required
                class="w-full px-4 py-3 rounded-lg border border-border bg-background/80 text-foreground placeholder:text-foreground/40 focus:outline-none focus:ring-2 focus:ring-primary-500"
              ></textarea>
            </div>

            <button
              type="submit"
              class="w-full bg-primary-500 text-primary-foreground py-3 rounded-lg font-medium hover:bg-primary-600 transition-colors flex items-center justify-center gap-2"
            >
              <span class="mr-2">
                </span>
              Send Message
            </button>
          </form>
        </div>

        {/* Contact Info */}
        <div class="space-y-6">
          <div class="space-y-4">
            <h3 class="text-lg font-semibold">
              Our Office
            </h3>
            <p class="text-foreground/60">
              Visa Itinerary Headquarters<br />
              123 Travel Ave<br />
              Global City, GC 12345<br />
              United Nations Territory
            </p>
          </div>

          <div class="space-y-4">
            <h3 class="text-lg font-semibold">
              Get in Touch
            </h3>
            <p class="space-y-2">
              <span class="font-medium">
                Email:
              </span>
              <a href="mailto:contact@visaitinerary.example.com" class="text-primary-500 hover:text-primary-600 transition-colors">
                contact@visaitinerary.example.com
              </a>
            </p>
            <p class="space-y-2">
              <span class="font-medium">
                Phone:
              </span>
              +1 (800) 555-VISA (8472)
            </p>
            <p class="space-y-2">
              <span class="font-medium">
                Hours:
              </span>
              Monday-Friday: 9:00 AM - 6:00 PM UTC
            </p>
          </div>

          <div class="space-y-4">
            <h3 class="text-lg font-semibold">
              Follow Us
            </h3>
            <div class="flex space-x-4">
              <a href="#" class="h-10 w-10 flex items-center justify-center bg-background/50 rounded-lg hover:bg-background/100 transition-colors">
                </a>
              <a href="#" class="h-10 w-10 flex items-center justify-center bg-background/50 rounded-lg hover:bg-background/100 transition-colors">
                </a>
              <a href="#" class="h-10 w-10 flex items-center justify-center bg-background/50 rounded-lg hover:bg-background/100 transition-colors">
                </a>
              <a href="#" class="h-10 w-10 flex items-center justify-center bg-background/50 rounded-lg hover:bg-background/100 transition-colors">
                </a>
              <a href="#" class="h-10 w-10 flex items-center justify-center bg-background/50 rounded-lg hover:bg-background/100 transition-colors">
                </a>
            </div>
          </div>
        </div>
      </div>
    </SectionHeader>
  </Container>
</SiteLayout>