---
import SiteLayout from '@/layouts/SiteLayout.astro';
import RegisterForm from '@/components/islands/RegisterForm';

async function getData() {
  return {
    props: {}
  };
}

const _data = await getData({ params: Astro.params });
const props = _data?.props || {};
---
<SiteLayout
  pageTitle="Create Account - Visa Itinerary"
  pageDescription="Join Visa Itinerary to access personalized visa recommendations, document generation, and application tracking."
>
  <RegisterForm client:load />
</SiteLayout>