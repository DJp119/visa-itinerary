---
import SiteLayout from '@/layouts/SiteLayout.astro';
import Container from '@/components/astro/Container.astro';
import SectionHeader from '@/components/astro/SectionHeader.astro';
import Breadcrumbs from '@/components/astro/Breadcrumbs.astro';
import DetailHero from '@/components/detail/DetailHero.astro';
import { getCountryStaticPaths } from '@/lib/urls/routes';
import type { Country } from '@/lib/schemas/country';
import type { HealthGuide } from '@/lib/schemas/health';
import { FixtureCountryRepository } from '@/data/repositories/countryRepository';
import { FixtureHealthRepository } from '@/data/repositories/healthRepository';

export async function getStaticPaths() {
  const countryRepo = new FixtureCountryRepository();
  const healthRepo = new FixtureHealthRepository();
  const paths = getCountryStaticPaths();
  
  const result = [];
  for (const path of paths) {
    const countryData = await countryRepo.getCountryBySlug(path.params.country);
    if (countryData) {
      const healthGuideData = await healthRepo.getHealthAdviceByCountryId(countryData.id);
      result.push({
        params: { country: path.params.country },
        props: { country: countryData, healthGuide: healthGuideData }
      });
    }
  }
  return result;
}

const { country, healthGuide } = Astro.props;
---

<SiteLayout
  pageTitle={`Health Guide for ${country.name}`}
  pageDescription={`Essential health information, vaccination requirements, and medical advice for travelers to ${country.name}.`}
>
  <Container>
    <Breadcrumbs
      items={[
        { label: 'Home', href: '/' },
        { label: 'Countries', href: '/#' },
        { label: country.name, href: `/${country.slug}` },
        { label: 'Health Guide', href: '' }
      ]}
    />

    <SectionHeader
      title={`Health Guide for ${country.name}`}
      description={`Essential health information, vaccination requirements, and medical advice for travelers to ${country.name}`}
    >
      <p class="text-lg text-foreground/60 mb-8">
        Stay healthy during your trip to {country.name} with our comprehensive health guide. From required vaccinations and health precautions to medical facilities and emergency information, we've got you covered.
      </p>
    </SectionHeader>
  </Container>
</SiteLayout>