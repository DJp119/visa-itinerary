---
import SiteLayout from '@/layouts/SiteLayout.astro';
import Container from '@/components/astro/Container.astro';
import SectionHeader from '@/components/astro/SectionHeader.astro';
import Breadcrumbs from '@/components/astro/Breadcrumbs.astro';
import { getCountryStaticPaths } from '@/lib/urls/routes';
import type { Country } from '@/lib/schemas/country';
import type { HealthGuide } from '@/lib/schemas/health';
import { FixtureCountryRepository } from '@/data/repositories/countryRepository';
import { FixtureHealthRepository } from '@/data/repositories/healthRepository';

// This is a static version - in a real implementation we would fetch from repository
export async function getStaticPaths() {
  return getCountryStaticPaths().map(path => ({
    params: {
      country: path.params.country,
      filter: path.params.filter  // This would be things like 'vaccinations', 'emergency', 'facilities', etc.
    }
  }));
}

// Get country and filtered health advice data
async function getData(props: { params: { country: string; filter: string } }) {
  const countryRepo = new FixtureCountryRepository();
  const healthRepo = new FixtureHealthRepository();

  // Get country data
  const countryData = await countryRepo.getCountryBySlug(props.params.country);

  // Handle case where country is not found
  if (!countryData) {
    return {
      props: {
        country: null,
        healthGuide: null,
        filter: props.params.filter
      }
    };
  }

  // Get all health advice for this country
  const allHealthGuides = await healthRepo.getHealthAdviceByCountryId(countryData.id);

  // Filter by the specified filter parameter
  // In a real implementation, this would filter by actual properties like topic, region, etc.
  // For now, we'll do a simple text match on title or description
  const filteredHealthGuides = allHealthGuides.filter(guide =>
    guide.title.toLowerCase().includes(props.params.filter.toLowerCase()) ||
    guide.description.toLowerCase().includes(props.params.filter.toLowerCase()) ||
    guide.content.toLowerCase().includes(props.params.filter.toLowerCase())
  );

  return {
    props: {
      country: countryData,
      healthGuide: filteredHealthGuides.length > 0 ? filteredHealthGuides[0] : null,
      filter: props.params.filter
    }
  };
}

const _data = await getData({ params: Astro.params });
const props = _data?.props || {};
---

<SiteLayout
  pageTitle={`Health Guide for ${props.country?.name} - ${props.filter}`}
  pageDescription=`Filtered health information for ${props.country?.name} related to ${props.filter}.`
>
  <Container>
    <Breadcrumbs
      items={[
        { label: 'Home', href: '/' },
        { label: 'Countries', href: '/#' },
        { label: props.country?.name || 'Country', href: `/${props.country?.slug}` },
        { label: 'Health Guide', href: `/${props.country?.slug}/health` },
        { label: props.filter, href: '' }
      ]}
    />

    <SectionHeader
      title={`Health Guide for ${props.country?.name} - ${props.filter}`}
      description={`Health information related to ${props.filter} for ${props.country?.name}`}
    >
      {props.healthGuide && (
        <>
          <p class="text-lg text-foreground/60 mb-8">
            Health information related to "{props.filter}".
          </p>

          <div class="mb-3">
            <h3 class="text-lg font-semibold text-foreground">
              {props.healthGuide.title}
            </h3>
            <p class="text-sm text-foreground/50">
              {props.healthGuide.description}
            </p>
          </div>

          {props.healthGuide.content && (
            <div class="prose prose-lg max-w-none">
              {props.healthGuide.content}
            </div>
          )}
        </>
      ) : (
        <div class="text-center py-8">
          <p class="text-lg text-foreground/50">
            No health information found for {props.country?.name} related to "{props.filter}".
          </p>
        </div>
      )}
    </SectionHeader>
  </Container>
</SiteLayout>