---
import SiteLayout from '@/layouts/SiteLayout.astro';
import Container from '@/components/astro/Container.astro';
import SectionHeader from '@/components/astro/SectionHeader.astro';
import Breadcrumbs from '@/components/astro/Breadcrumbs.astro';
import DetailHero from '@/components/detail/DetailHero.astro';
import { getCountryStaticPaths } from '@/lib/urls/routes';
import type { Country } from '@/lib/schemas/country';
import type { VisaRequirement } from '@/lib/schemas/visa';
import { FixtureCountryRepository } from '@/data/repositories/countryRepository';
import { FixtureVisaRepository } from '@/data/repositories/visaRepository';

// This is a static version - in a real implementation we would fetch from repository
export async function getStaticPaths() {
  return getCountryStaticPaths().map(path => ({
    params: { country: path.params.country }
  }));
}

// Get country and digital nomad visa data
async function getData(props: { params: { country: string } }) {
  const countryRepo = new FixtureCountryRepository();
  const visaRepo = new FixtureVisaRepository();

  // Get country data
  const countryData = await countryRepo.getCountryBySlug(props.params.country);

  // Handle case where country is not found
  if (!countryData) {
    return {
      props: {
        country: null,
        digitalNomadVisas: []
      }
    };
  }

  // Get all visa requirements for this destination country
  const allVisaRequirements = await visaRepo.getVisaRequirementsByDestination(countryData.id);

  // Filter to only digital-nomad visas
  const digitalNomadVisas = allVisaRequirements.filter(
    req => req.kind === 'digital-nomad'
  );

  return {
    props: {
      country: countryData,
      digitalNomadVisas: digitalNomadVisas
    }
  };
}

const _data = await getData({ params: Astro.params as any });
const props = _data?.props || {};
---

<SiteLayout
  pageTitle={`Digital Nomad Visas for ${props.country?.name}`}
  pageDescription={`Digital nomad visa requirements and programs for ${props.country?.name}.`}
>
  <Container>
    <Breadcrumbs
      items={[
        { label: 'Home', href: '/' },
        { label: 'Countries', href: '/#' },
        { label: props.country?.name || 'Country', href: `/${props.country?.slug}` },
        { label: 'Visas', href: `/${props.country?.slug}/visa` },
        { label: 'Digital Nomad Visas', href: '' }
      ]}
    />

    <SectionHeader
      title={`Digital Nomad Visas for ${props.country?.name}`}
      description={`Requirements for staying and working remotely in ${props.country?.name}`}
    >
      <p class="text-lg text-foreground/60 mb-8">
        Information about digital nomad visa programs that allow remote workers to live and work in
        {props.country?.name} for extended periods.
      </p>
    </SectionHeader>

    {props.digitalNomadVisas && props.digitalNomadVisas.length > 0 ? (
      <div class="space-y-6">
        {props.digitalNomadVisas.map((visa, index) => (
          <div key={index} class="border border-border/50 rounded-lg p-6 bg-background/50">
            <div class="mb-4">
              <h3 class="text-lg font-semibold text-foreground">
                Visa for {visa.passportCountry?.name || 'Unknown'} nationals
              </h3>
              <p class="text-sm text-foreground/50">
                {visa.requirement?.replace('-', ' ').title()} • {visa.stayDays} days stay
              </p>
            </div>

            <div class="space-y-3">
              <div class="space-y-2">
                <span class="font-medium">Processing Time:</span>
                <span class="ml-auto">
                  {visa.processingDays ? (
                    `${visa.processingDays.min}-${visa.processingDays.max} days`
                  ) : (
                    'Varies'
                  )}
                </span>
              </div>

              {visa.fee && (
                <div class="space-y-2">
                  <span class="font-medium">Fee:</span>
                  <span class="ml-auto">
                    {visa.fee.amount} {visa.fee.currencyCode}
                  </span>
                </div>
              )}

              <div class="space-y-2">
                <span class="font-medium">Conditions:</span>
                <ul class="ml-4 list-disc space-y-1 text-sm text-foreground/60">
                  {visa.conditions?.map((condition, idx) => (
                    <li key={idx}>
                      {condition}
                    </li>
                  ))}
                </ul>
              </div>

              <div class="space-y-2">
                <span class="font-medium">Required Documents:</span>
                <ul class="ml-4 list-disc space-y-1 text-sm text-foreground/60">
                  {visa.documents?.map((doc, idx) => (
                    <li key={idx}>
                      {doc}
                    </li>
                  ))}
                </ul>
              </div>

              {visa.sourceUrls && visa.sourceUrls.length > 0 && (
                <div class="mt-4 space-y-2">
                  <span class="font-medium">Sources:</span>
                  <ul class="ml-4 list-disc space-y-1 text-sm text-foreground/60">
                    {visa.sourceUrls?.map((url, idx) => (
                      <li key={idx}>
                        <a href={url} class="underline" target="_blank" rel="noopener noreferrer">
                          Source {idx + 1}
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              )}
            </div>
          </div>
        ))}
      </div>
    ) : (
      <div class="text-center py-8">
        <p class="text-lg text-foreground/50">
          No digital nomad visa programs currently available for {props.country?.name}.
        </p>
      </div>
    )}
  </Container>
</SiteLayout>