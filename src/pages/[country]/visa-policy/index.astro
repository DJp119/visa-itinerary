---
import SiteLayout from '@/layouts/SiteLayout.astro';
import Container from '@/components/astro/Container.astro';
import SectionHeader from '@/components/astro/SectionHeader.astro';
import Breadcrumbs from '@/components/astro/Breadcrumbs.astro';
import DetailHero from '@/components/detail/DetailHero.astro';
import { getCountryStaticPaths } from '@/lib/urls/routes';
import type { Country } from '@/lib/schemas/country';
import type { VisaPolicy } from '@/lib/schemas/visa';
import { FixtureCountryRepository } from '@/data/repositories/countryRepository';
import { FixtureVisaRepository } from '@/data/repositories/visaRepository';

// This is a static version - in a real implementation we would fetch from repository
export async function getStaticPaths() {
  return getCountryStaticPaths().map(path => ({
    params: { country: path.params.country }
  }));
}

// Get country and visa policy data
export async function get(props: { params: { country: string } }) {
  const countryRepo = new FixtureCountryRepository();
  const visaRepo = new FixtureVisaRepository();

  // Get country data
  const countryData = await countryRepo.getCountryBySlug(props.params.country);

  // Handle case where country is not found
  if (!countryData) {
    return {
      props: {
        country: null,
        visaPolicy: null
      }
    };
  }

  // Get visa policy data for this country
  const visaPolicyData = await visaRepo.getVisaPolicyByCountryId(countryData.id);

  return {
    props: {
      country: countryData,
      visaPolicy: visaPolicyData
    }
  };
}
---

<SiteLayout
  pageTitle={`Visa Policy for ${props.country?.name}`}
  pageDescription=`Official visa policy and immigration regulations for ${props.country?.name}.`
>
  <Container>
    <Breadcrumbs
      items={[
        { label: 'Home', href: '/' },
        { label: 'Countries', href: '/#' },
        { label: props.country?.name || 'Country', href: `/${props.country?.slug}` },
        { label: 'Visas', href: `/${props.country?.slug}/visa` },
        { label: 'Visa Policy', href: '' }
      ]}
    />

    <SectionHeader
      title={`Visa Policy for ${props.country?.name}`}
      description={`Official visa policy and immigration regulations for ${props.country?.name}`}
    >
      {props.visaPolicy && (
        <>
          <p class="text-lg text-foreground/60 mb-8">
            {props.visaPolicy.description}
          </p>

          {props.visaPolicy.content && (
            <div class="prose prose-lg max-w-none">
              {props.visaPolicy.content}
            </div>
          )}
        </>
      )}

      {!props.visaPolicy && (
        <p class="text-lg text-foreground/60 mb-8">
          Visa policy information for {props.country?.name} is not available.
        </p>
      )}
    </SectionHeader>
  </Container>
</SiteLayout>