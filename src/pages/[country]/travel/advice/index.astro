---
import SiteLayout from '@/layouts/SiteLayout.astro';
import Container from '@/components/astro/Container.astro';
import SectionHeader from '@/components/astro/SectionHeader.astro';
import Breadcrumbs from '@/components/astro/Breadcrumbs.astro';
import DetailHero from '@/components/detail/DetailHero.astro';
import { getCountryStaticPaths } from '@/lib/urls/routes';
import type { Country } from '@/lib/schemas/country';
import type { TravelAdvice } from '@/lib/schemas/travel';
import { FixtureCountryRepository } from '@/data/repositories/countryRepository';
import { FixtureTravelRepository } from '@/data/repositories/travelRepository';

// This is a static version - in a real implementation we would fetch from repository
export async function getStaticPaths() {
  return getCountryStaticPaths().map(path => ({
    params: { country: path.params.country }
  }));
}

// Get country and travel advice data
export async function get(props: { params: { country: string } }) {
  const countryRepo = new FixtureCountryRepository();
  const travelRepo = new FixtureTravelRepository();

  // Get country data
  const countryData = await countryRepo.getCountryBySlug(props.params.country);

  // Handle case where country is not found
  if (!countryData) {
    return {
      props: {
        country: null,
        travelAdvice: null
      }
    };
  }

  // Get travel advice data for this country
  const travelAdviceData = await travelRepo.getTravelAdviceByCountryId(countryData.id);

  return {
    props: {
      country: countryData,
      travelAdvice: travelAdviceData
    }
  };
}
---

<SiteLayout
  pageTitle={`Travel Advice for ${props.country?.name}`}
  pageDescription=`Essential travel advice and tips for visiting ${props.country?.name}.`
>
  <Container>
    <Breadcrumbs
      items={[
        { label: 'Home', href: '/' },
        { label: 'Countries', href: '/#' },
        { label: props.country?.name || 'Country', href: `/${props.country?.slug}` },
        { label: 'Travel Guide', href: `/${props.country?.slug}/travel` },
        { label: 'Travel Advice', href: '' }
      ]}
    />

    <SectionHeader
      title={`Travel Advice for ${props.country?.name}`}
      description={`Essential tips and recommendations for visiting ${props.country?.name}`}
    >
      {props.travelAdvice && (
        <>
          <p class="text-lg text-foreground/60 mb-8">
            {props.travelAdvice.description}
          </p>

          {props.travelAdvice.content && (
            <div class="prose prose-lg max-w-none">
              {props.travelAdvice.content}
            </div>
          )}
        </>
      )}

      {!props.travelAdvice && (
        <p class="text-lg text-foreground/60 mb-8">
          Travel advice for {props.country?.name} is not available.
        </p>
      )}
    </SectionHeader>
  </Container>
</SiteLayout>