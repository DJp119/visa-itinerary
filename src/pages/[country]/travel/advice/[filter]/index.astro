---
import SiteLayout from '@/layouts/SiteLayout.astro';
import Container from '@/components/astro/Container.astro';
import SectionHeader from '@/components/astro/SectionHeader.astro';
import Breadcrumbs from '@/components/astro/Breadcrumbs.astro';
import { getCountryStaticPaths } from '@/lib/urls/routes';
import type { Country } from '@/lib/schemas/country';
import type { TravelAdvice } from '@/lib/schemas/travel';
import { FixtureCountryRepository } from '@/data/repositories/countryRepository';
import { FixtureTravelRepository } from '@/data/repositories/travelRepository';

// This is a static version - in a real implementation we would fetch from repository
export async function getStaticPaths() {
  return getCountryStaticPaths().map(path => ({
    params: {
      country: path.params.country,
      filter: path.params.filter  // This would be things like 'health', 'safety', 'customs', etc.
    }
  }));
}

// Get country and filtered travel advice data
async function getData(props: { params: { country: string; filter: string } }) {
  const countryRepo = new FixtureCountryRepository();
  const travelRepo = new FixtureTravelRepository();

  // Get country data
  const countryData = await countryRepo.getCountryBySlug(props.params.country);

  // Handle case where country is not found
  if (!countryData) {
    return {
      props: {
        country: null,
        travelAdvice: [],
        filter: props.params.filter
      }
    };
  }

  // Get all travel advice for this country
  const allAdvice = await travelRepo.getTravelAdviceByCountryId(countryData.id);

  // Filter by the specified filter parameter
  // In a real implementation, this would filter by actual properties like topic, region, etc.
  // For now, we'll do a simple text match on title or description
  const filteredAdvice = allAdvice.filter(advice =>
    advice.title.toLowerCase().includes(props.params.filter.toLowerCase()) ||
    advice.description.toLowerCase().includes(props.params.filter.toLowerCase()) ||
    advice.content.toLowerCase().includes(props.params.filter.toLowerCase())
  );

  return {
    props: {
      country: countryData,
      travelAdvice: filteredAdvice,
      filter: props.params.filter
    }
  };
}

const _data = await getData({ params: Astro.params });
const props = _data?.props || {};
---

<SiteLayout
  pageTitle={`Travel Advice for ${props.country?.name} - ${props.filter}`}
  pageDescription=`Filtered travel advice for ${props.country?.name} related to ${props.filter}.`
>
  <Container>
    <Breadcrumbs
      items={[
        { label: 'Home', href: '/' },
        { label: 'Countries', href: '/#' },
        { label: props.country?.name || 'Country', href: `/${props.country?.slug}` },
        { label: 'Travel Guide', href: `/${props.country?.slug}/travel` },
        { label: 'Travel Advice', href: `/${props.country?.slug}/travel/advice` },
        { label: props.filter, href: '' }
      ]}
    />

    <SectionHeader
      title={`Travel Advice for ${props.country?.name} - ${props.filter}`}
      description={`Travel advice related to ${props.filter} for visiting ${props.country?.name}`}
    >
      {props.travelAdvice && props.travelAdvice.length > 0 ? (
        <>
          <p class="text-lg text-foreground/60 mb-8">
            Found {props.travelAdvice.length} travel advice items related to "{props.filter}".
          </p>

          <div class="space-y-6">
            {props.travelAdvice.map((advice, index) => (
              <div key={index} class="border border-border/50 rounded-lg p-6 bg-background/50">
                <div class="mb-3">
                  <h3 class="text-lg font-semibold text-foreground">
                    {advice.title}
                  </h3>
                  <p class="text-sm text-foreground/50">
                    {advice.description}
                  </p>
                </div>

                {advice.content && (
                  <div class="prose prose-lg max-w-none">
                    {advice.content}
                  </div>
                )}
              </div>
            ))}
          </div>
        </>
      ) : (
        <div class="text-center py-8">
          <p class="text-lg text-foreground/50">
            No travel advice found for {props.country?.name} related to "{props.filter}".
          </p>
        </div>
      )}
    </SectionHeader>
  </Container>
</SiteLayout>