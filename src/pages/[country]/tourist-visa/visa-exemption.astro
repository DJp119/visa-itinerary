---
import SiteLayout from '@/layouts/SiteLayout.astro';
import Container from '@/components/astro/Container.astro';
import SectionHeader from '@/components/astro/SectionHeader.astro';
import Breadcrumbs from '@/components/astro/Breadcrumbs.astro';
import DetailHero from '@/components/detail/DetailHero.astro';
import { getCountryStaticPaths } from '@/lib/urls/routes';
import type { Country } from '@/lib/schemas/country';
import type { VisaRequirement } from '@/lib/schemas/visa';

import { FixtureCountryRepository } from '@/data/repositories/countryRepository';
import { FixtureVisaRepository } from '@/data/repositories/visaRepository';

// This is a static version - in a real implementation we would fetch from repository
export async function getStaticPaths() {
  // In a real implementation, we would get country data and then for countries that have exemptions
  const countryPaths = getCountryStaticPaths();
  const paths: { params: { country: string } }[] = [];

  // For demo, we'll add countries that have exemptions
  const countriesWithExemptions = ['jp', 'de', 'fr', 'sg'];  // Japan, Germany, France, Singapore

  return countriesWithExemptions.map(country => ({
    params: { country }
  }));
}

// Get country and visa exemption data
export async function get(props: { params: { country: string } }) {
  const countryRepo = new FixtureCountryRepository();
  const visaRepo = new FixtureVisaRepository();

  // Get country data
  const countryData = await countryRepo.getCountryBySlug(props.params.country);

  // Handle case where country is not found
  if (!countryData) {
    return {
      props: {
        country: null,
        visaExemptions: []
      }
    };
  }

  // Get visa exemptions for this country (passport countries that can visit this country visa-free)
  // We'll get all visa requirements for this destination and filter for visa-free tourist visas
  const allRequirements = await visaRepo.getVisaRequirementsByDestination(countryData.id);
  const visaExemptions = allRequirements.filter(
    req => req.kind === 'tourist' && req.requirement === 'visa-free'
  );

  return {
    props: {
      country: countryData,
      visaExemptions: visaExemptions
    }
  };
}
---

<SiteLayout
  pageTitle=`Visa Exemptions for ${props.country.name}`}
  pageDescription=`Find which nationalities can visit ${props.country.name} without a visa.`
>
  <Container>
    <Breadcrumbs
      items={[
        { label: 'Home', href: '/' },
        { label: 'Countries', href: '/#' },
        { label: props.country.name, href: `/${props.country.slug}` },
        { label: 'Tourist Visas', href: `/${props.country.slug}/tourist` },
        { label: 'Visa Exemptions', href: '' }
      ]}
    />

    <SectionHeader
      title={`Visa Exemptions for ${props.country.name}`}
      description={`Find which nationalities can visit ${props.country.name} without a visa`}
    >
      <p class="text-lg text-foreground/60 mb-8">
        Discover which passport holders can visit {props.country.name} for tourism without needing to obtain a visa in advance.
      </p>
    </SectionHeader>
  </Container>
</SiteLayout>