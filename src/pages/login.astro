---
import SiteLayout from '@/layouts/SiteLayout.astro';
import LoginForm from '@/components/islands/LoginForm';

async function getData() {
  return {
    props: {}
  };
}

const _data = await getData({ params: Astro.params });
const props = _data?.props || {};
---
<SiteLayout
  pageTitle="Login to Visa Itinerary"
  pageDescription="Sign in to access personalized visa recommendations, document generation, and application tracking."
>
  <LoginForm client:load />
</SiteLayout>