---
import SiteLayout from '@/layouts/SiteLayout.astro';
import Container from '@/components/astro/Container.astro';
import SectionHeader from '@/components/astro/SectionHeader.astro';
---

<SiteLayout
  pageTitle="Page Not Found"
  pageDescription="The page you're looking for doesn't exist or has been moved."
>
  <Container>
    <section class="min-h-[calc(100vh-160px)] flex items-center justify-center text-center py-12">
      <div class="space-y-8">
        <div>
          <span class="text-9xl">404</span>
        </div>
        <h1 class="text-4xl font-bold text-foreground">
          Page Not Found
        </h1>
        <p class="text-lg text-foreground/60 mb-6">
          The page you're looking for doesn't exist or has been moved.
        </p>
        <div class="flex justify-center space-x-4">
          <a href="/" class="bg-primary-500 text-primary-foreground px-6 py-3 rounded-lg hover:bg-primary-600 transition-colors">
            Return to Homepage
          </a>
          <a href="/visa" class="text-primary-500 hover:text-primary-600 transition-colors ml-4">
            Visit Visa Directory
          </a>
        </div>
      </div>
    </section>
  </Container>
</SiteLayout>