{
  "$ref": "#/definitions/visa",
  "definitions": {
    "visa": {
      "type": "object",
      "properties": {
        "destinationCountryId": {
          "type": "string"
        },
        "passportCountryId": {
          "type": "string"
        },
        "kind": {
          "type": "string",
          "enum": [
            "tourist",
            "transit",
            "digital-nomad"
          ]
        },
        "requirement": {
          "type": "string",
          "enum": [
            "visa-free",
            "visa-on-arrival",
            "evisa",
            "sticker-visa",
            "visa-refused",
            "not-available"
          ]
        },
        "stayDays": {
          "type": "number"
        },
        "processingDays": {
          "type": "object",
          "properties": {
            "min": {
              "type": "number"
            },
            "max": {
              "type": "number"
            }
          },
          "required": [
            "min",
            "max"
          ],
          "additionalProperties": false
        },
        "fee": {
          "type": "object",
          "properties": {
            "amount": {
              "type": "number"
            },
            "currencyCode": {
              "type": "string",
              "minLength": 3,
              "maxLength": 3
            }
          },
          "required": [
            "amount",
            "currencyCode"
          ],
          "additionalProperties": false
        },
        "applicationUrl": {
          "type": "string",
          "format": "uri"
        },
        "conditions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "documents": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "sourceUrls": {
          "type": "array",
          "items": {
            "type": "string",
            "format": "uri"
          }
        },
        "verifiedAt": {
          "type": "string",
          "format": "date-time"
        },
        "confidence": {
          "type": "string",
          "enum": [
            "official",
            "partner",
            "community-review",
            "unknown"
          ]
        },
        "$schema": {
          "type": "string"
        }
      },
      "required": [
        "destinationCountryId",
        "passportCountryId",
        "kind",
        "requirement",
        "conditions",
        "documents",
        "sourceUrls",
        "verifiedAt",
        "confidence"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}