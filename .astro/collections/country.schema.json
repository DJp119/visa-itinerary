{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "code": {
      "type": "string",
      "minLength": 2,
      "maxLength": 2
    },
    "continent": {
      "type": "string"
    },
    "population": {
      "type": "number"
    },
    "capital": {
      "type": "string"
    },
    "currency": {
      "type": "string"
    },
    "language": {
      "type": "string"
    },
    "timezone": {
      "type": "string"
    },
    "noindex": {
      "default": false,
      "type": "boolean"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "name",
    "code",
    "continent"
  ]
}